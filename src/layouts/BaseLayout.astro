---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "The simplest way to handle contact form submissions. No backend needed." } = Astro.props;
const fullTitle = title === "Home" ? "ContactFormAPI — Form Backend as a Service" : `${title} — ContactFormAPI`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/contactformapilogo.png" />
    <link rel="icon" type="image/svg+xml" href="/contactformapilogo.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{fullTitle}</title>
  </head>
  <body class="min-h-screen bg-white text-surface-900 antialiased flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
