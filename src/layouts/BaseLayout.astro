---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "The simplest way to handle contact form submissions. No backend needed.",
} = Astro.props;
const fullTitle = title === "Home"
  ? "ContactFormAPI — Form Backend as a Service"
  : `${title} — ContactFormAPI`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/contactformapilogo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <title>{fullTitle}</title>
  </head>
  <body class="relative min-h-screen bg-gradient-to-b from-amber-50 via-orange-50/40 to-amber-50 text-gray-900 antialiased flex flex-col">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
      <div class="absolute top-24 left-1/2 h-[320px] w-[560px] -translate-x-1/2 rounded-full bg-amber-200/25 blur-[90px]"></div>
      <div class="absolute top-[45%] -left-20 h-56 w-56 rounded-full bg-orange-200/20 blur-[80px]"></div>
      <div class="absolute bottom-24 -right-24 h-64 w-64 rounded-full bg-amber-300/15 blur-[90px]"></div>
    </div>

    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
