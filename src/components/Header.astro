---
const navLinks = [
  { label: "Product", href: "/#product" },
  { label: "Features", href: "/#features" },
  { label: "Integrations", href: "/#integrations" },
  { label: "Developers", href: "/docs" },
  { label: "Pricing", href: "/pricing" },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white">
  <div class="mx-auto flex h-14 max-w-[1200px] items-center justify-between px-6">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2">
      <img src="/contactformapilogo.svg" alt="" class="h-6 w-6" />
      <span class="text-[14px] font-semibold text-gray-900 tracking-[-0.01em]">ContactFormAPI</span>
    </a>

    <!-- Center nav -->
    <nav class="hidden items-center gap-7 lg:flex">
      {navLinks.map((link) => (
        <a href={link.href} class="text-[13px] text-gray-500 hover:text-gray-900 transition-colors">
          {link.label}
        </a>
      ))}
    </nav>

    <!-- CTA -->
    <div class="hidden sm:block">
      <a
        href="https://app.contactformapi.com/register"
        class="rounded-full bg-gray-900 px-5 py-2 text-[13px] font-medium text-white hover:bg-gray-800 transition-colors"
      >
        Launch App
      </a>
    </div>

    <button id="mobile-menu-btn" class="p-1.5 text-gray-500 lg:hidden" aria-label="Menu">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5m-16.5 6.75h16.5" />
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden border-t border-gray-100 bg-white lg:hidden">
    <div class="px-6 py-4 space-y-1">
      {navLinks.map((link) => (
        <a href={link.href} class="block py-2 text-[14px] text-gray-500 hover:text-gray-900">{link.label}</a>
      ))}
      <a href="https://app.contactformapi.com/register" class="mt-3 block rounded-full bg-gray-900 px-5 py-2.5 text-center text-[14px] font-medium text-white">Launch App</a>
    </div>
  </div>
</header>

<script>
  document.getElementById("mobile-menu-btn")?.addEventListener("click", () => {
    document.getElementById("mobile-menu")?.classList.toggle("hidden");
  });
</script>
