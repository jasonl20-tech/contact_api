---
const navLinks = [
  { label: "Product", href: "/" },
  { label: "Pricing", href: "/pricing" },
  { label: "Blog", href: "/blog" },
  { label: "Docs", href: "/docs" },
];
---

<header class="sticky top-0 z-50 border-b border-surface-200 bg-white/80 backdrop-blur-lg">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <a href="/" class="flex items-center gap-2 text-lg font-bold tracking-tight text-surface-900">
      <img src="/contactformapilogo.svg" alt="ContactFormAPI Logo" class="h-8 w-8" />
      ContactFormAPI
    </a>

    <nav class="hidden items-center gap-1 md:flex">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="rounded-lg px-3 py-2 text-sm font-medium text-surface-600 transition-colors hover:bg-surface-100 hover:text-surface-900"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="https://app.contactformapi.com/login"
        class="hidden text-sm font-medium text-surface-600 transition-colors hover:text-surface-900 sm:block"
      >
        Sign in
      </a>
      <a
        href="https://app.contactformapi.com/register"
        class="inline-flex items-center rounded-lg bg-primary-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition-all hover:bg-primary-700 hover:shadow-md"
      >
        Get Started Free
      </a>
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="rounded-lg p-2 text-surface-600 hover:bg-surface-100 md:hidden"
      aria-label="Toggle menu"
    >
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-surface-200 bg-white md:hidden">
    <div class="space-y-1 px-4 py-3">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="block rounded-lg px-3 py-2 text-sm font-medium text-surface-600 hover:bg-surface-100 hover:text-surface-900"
        >
          {link.label}
        </a>
      ))}
      <div class="border-t border-surface-200 pt-3">
        <a href="https://app.contactformapi.com/login" class="block px-3 py-2 text-sm font-medium text-surface-600">
          Sign in
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>
