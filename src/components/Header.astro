---
const navLinks = [
  { label: "Features", href: "/#features" },
  { label: "Pricing", href: "/pricing" },
  { label: "Blog", href: "/blog" },
  { label: "Docs", href: "/docs" },
];
---

<header class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-gray-100">
  <div class="mx-auto flex h-14 max-w-6xl items-center justify-between px-5">
    <a href="/" class="flex items-center gap-2">
      <img src="/contactformapilogo.svg" alt="ContactFormAPI" class="h-7 w-7" />
      <span class="text-[15px] font-semibold text-gray-900">ContactFormAPI</span>
    </a>

    <nav class="hidden items-center gap-6 md:flex">
      {navLinks.map((link) => (
        <a href={link.href} class="text-[13px] text-gray-500 transition-colors hover:text-gray-900">
          {link.label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-4 sm:flex">
      <a href="https://app.contactformapi.com/login" class="text-[13px] text-gray-500 hover:text-gray-900">
        Log in
      </a>
      <a
        href="https://app.contactformapi.com/register"
        class="rounded-full bg-gray-900 px-4 py-1.5 text-[13px] font-medium text-white transition-colors hover:bg-gray-800"
      >
        Get Started
      </a>
    </div>

    <button id="mobile-menu-btn" class="rounded-lg p-1.5 text-gray-500 md:hidden" aria-label="Menu">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5m-16.5 6.75h16.5" />
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden border-t border-gray-100 bg-white md:hidden">
    <div class="px-5 py-3 space-y-1">
      {navLinks.map((link) => (
        <a href={link.href} class="block py-2 text-sm text-gray-500 hover:text-gray-900">{link.label}</a>
      ))}
      <div class="flex items-center gap-3 pt-3 border-t border-gray-100">
        <a href="https://app.contactformapi.com/login" class="text-sm text-gray-500">Log in</a>
        <a href="https://app.contactformapi.com/register" class="rounded-full bg-gray-900 px-4 py-1.5 text-sm font-medium text-white">Get Started</a>
      </div>
    </div>
  </div>
</header>

<script>
  document.getElementById("mobile-menu-btn")?.addEventListener("click", () => {
    document.getElementById("mobile-menu")?.classList.toggle("hidden");
  });
</script>
