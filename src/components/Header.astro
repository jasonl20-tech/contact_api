---
const navLinks = [
  { label: "Features", href: "/#features" },
  { label: "How it works", href: "/#how-it-works" },
  { label: "Pricing", href: "/pricing" },
  { label: "Blog", href: "/blog" },
];
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-white/10 bg-navy-950/80 backdrop-blur-xl">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-5 sm:px-8">
    <a href="/" class="flex items-center gap-2.5">
      <img src="/contactformapilogo.svg" alt="ContactFormAPI" class="h-8 w-8" />
      <span class="text-lg font-bold text-white">
        Contact<span class="text-amber-400">Form</span>API
      </span>
    </a>

    <nav class="hidden items-center gap-1 lg:flex">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="rounded-lg px-3.5 py-2 text-[13px] font-medium text-slate-300 transition-colors hover:text-white"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-3 sm:flex">
      <a
        href="https://app.contactformapi.com/login"
        class="text-[13px] font-medium text-slate-300 transition-colors hover:text-white"
      >
        Log in
      </a>
      <a
        href="https://app.contactformapi.com/register"
        class="inline-flex items-center rounded-lg bg-amber-500 px-4 py-2 text-[13px] font-semibold text-navy-950 transition-all hover:bg-amber-400 hover:shadow-lg hover:shadow-amber-500/20"
      >
        Start Free
      </a>
    </div>

    <button
      id="mobile-menu-btn"
      class="rounded-lg p-2 text-slate-300 hover:text-white lg:hidden"
      aria-label="Menu"
    >
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden border-t border-white/10 bg-navy-950 lg:hidden">
    <div class="space-y-1 px-5 py-4">
      {navLinks.map((link) => (
        <a href={link.href} class="block rounded-lg px-3 py-2.5 text-sm font-medium text-slate-300 hover:bg-white/5 hover:text-white">
          {link.label}
        </a>
      ))}
      <div class="flex items-center gap-3 border-t border-white/10 pt-4 mt-2">
        <a href="https://app.contactformapi.com/login" class="text-sm font-medium text-slate-300">Log in</a>
        <a href="https://app.contactformapi.com/register" class="rounded-lg bg-amber-500 px-4 py-2 text-sm font-semibold text-navy-950">Start Free</a>
      </div>
    </div>
  </div>
</header>

<script>
  document.getElementById("mobile-menu-btn")?.addEventListener("click", () => {
    document.getElementById("mobile-menu")?.classList.toggle("hidden");
  });
</script>
