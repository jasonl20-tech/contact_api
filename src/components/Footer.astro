---
const year = new Date().getFullYear();

const cols = {
  Product: [
    { label: "Features", href: "/#features" },
    { label: "Pricing", href: "/pricing" },
    { label: "Documentation", href: "/docs" },
  ],
  Resources: [
    { label: "Blog", href: "/blog" },
    { label: "Changelog", href: "/changelog" },
    { label: "Support", href: "/support" },
  ],
  Legal: [
    { label: "Privacy", href: "/privacy" },
    { label: "Terms", href: "/terms" },
    { label: "Imprint", href: "/imprint" },
  ],
};
---

<footer class="border-t border-gray-100 bg-white px-5">
  <div class="mx-auto max-w-6xl py-12">
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-2">
          <img src="/contactformapilogo.svg" alt="ContactFormAPI" class="h-6 w-6" />
          <span class="text-[14px] font-semibold text-gray-900">ContactFormAPI</span>
        </a>
        <p class="mt-3 text-[13px] leading-relaxed text-gray-400 max-w-[200px]">
          The simplest form backend service. No servers required.
        </p>
      </div>

      {Object.entries(cols).map(([cat, items]) => (
        <div>
          <p class="text-[11px] font-medium uppercase tracking-widest text-gray-400">{cat}</p>
          <ul class="mt-3 space-y-2">
            {items.map((l) => (
              <li>
                <a href={l.href} class="text-[13px] text-gray-500 hover:text-gray-900 transition-colors">
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-10 border-t border-gray-100 pt-5">
      <p class="text-[12px] text-gray-400">&copy; {year} ContactFormAPI</p>
    </div>
  </div>
</footer>
