---
const year = new Date().getFullYear();

const cols = {
  Product: [
    { label: "Features", href: "/#features" },
    { label: "Pricing", href: "/pricing" },
    { label: "Docs", href: "/docs" },
  ],
  Resources: [
    { label: "Blog", href: "/blog" },
    { label: "Changelog", href: "/changelog" },
    { label: "Support", href: "/support" },
  ],
  Legal: [
    { label: "Privacy", href: "/privacy" },
    { label: "Terms", href: "/terms" },
    { label: "Imprint", href: "/imprint" },
  ],
};
---

<footer class="border-t border-gray-100 px-6">
  <div class="mx-auto max-w-[1200px] py-14">
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4">
          <img src="/contactformapilogo.svg" alt="" class="h-5 w-5" />
          <span class="text-[13px] font-semibold text-gray-900">ContactFormAPI</span>
        </a>
        <p class="text-[13px] leading-relaxed text-gray-400 max-w-[180px]">
          The simplest form backend. No servers required.
        </p>
      </div>

      {Object.entries(cols).map(([cat, items]) => (
        <div>
          <p class="text-[11px] font-medium uppercase tracking-[0.08em] text-gray-400 mb-3">{cat}</p>
          <ul class="space-y-2">
            {items.map((l) => (
              <li>
                <a href={l.href} class="text-[13px] text-gray-500 hover:text-gray-900 transition-colors">{l.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 pt-5 border-t border-gray-100 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
      <p class="text-[12px] text-gray-400">&copy; {year} ContactFormAPI. All rights reserved.</p>
      <div class="flex items-center gap-4">
        <a href="/privacy" class="text-[12px] text-gray-400 hover:text-gray-600">Privacy</a>
        <a href="/terms" class="text-[12px] text-gray-400 hover:text-gray-600">Terms</a>
      </div>
    </div>
  </div>
</footer>
