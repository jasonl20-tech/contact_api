---
const year = new Date().getFullYear();

const links = {
  Product: [
    { label: "Features", href: "/#features" },
    { label: "Pricing", href: "/pricing" },
    { label: "Documentation", href: "/docs" },
  ],
  Resources: [
    { label: "Blog", href: "/blog" },
    { label: "Changelog", href: "/changelog" },
    { label: "Support", href: "/support" },
  ],
  Legal: [
    { label: "Privacy Policy", href: "/privacy" },
    { label: "Terms of Service", href: "/terms" },
    { label: "Imprint", href: "/imprint" },
  ],
};
---

<footer class="border-t border-white/5 bg-navy-950">
  <div class="mx-auto max-w-7xl px-5 py-16 sm:px-8">
    <div class="grid grid-cols-2 gap-10 md:grid-cols-4">
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-2.5">
          <img src="/contactformapilogo.svg" alt="ContactFormAPI" class="h-7 w-7" />
          <span class="text-base font-bold text-white">
            Contact<span class="text-amber-400">Form</span>API
          </span>
        </a>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-slate-500">
          The simplest form backend. Handle submissions, filter spam, send notifications.
        </p>
      </div>

      {Object.entries(links).map(([cat, items]) => (
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-widest text-slate-400">{cat}</h3>
          <ul class="mt-4 space-y-2.5">
            {items.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-slate-500 transition-colors hover:text-amber-400">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 border-t border-white/5 pt-6">
      <p class="text-center text-xs text-slate-600">
        &copy; {year} ContactFormAPI. All rights reserved.
      </p>
    </div>
  </div>
</footer>
