---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPages, getPageBySlug } from "../lib/contentful";
import { renderRichText } from "../lib/rich-text";

export async function getStaticPaths() {
  let pages: any[] = [];
  try { pages = await getPages(); } catch { return []; }
  return pages.map((p: any) => ({ params: { slug: p.fields.slug } }));
}

const { slug } = Astro.params;
const page = await getPageBySlug(slug!);
if (!page) return Astro.redirect("/");

const f = page.fields as any;
const html = renderRichText(f.body);
---

<BaseLayout title={f.seoTitle || f.title} description={f.seoDescription || f.description}>
  <section class="bg-navy-950 pt-32 pb-16 sm:pt-40 sm:pb-20">
    <div class="mx-auto max-w-3xl px-5 sm:px-8 text-center">
      <h1 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
        {f.title}
      </h1>
    </div>
  </section>

  <section class="bg-white py-12 sm:py-16">
    <div class="mx-auto max-w-3xl px-5 sm:px-8">
      <div class="prose prose-slate prose-lg max-w-none" set:html={html} />
    </div>
  </section>
</BaseLayout>
