---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getProducts, formatPrice, type PolarProduct, type PolarPrice } from "../lib/polar";

let products: PolarProduct[] = [];
let error: string | null = null;

try {
  products = await getProducts();
} catch (e) {
  error = "Plans could not be loaded. Please try again later.";
  console.error("Failed to fetch products:", e);
}

function getMonthlyPrice(product: PolarProduct): PolarPrice | undefined {
  return product.prices.find((p) => p.type === "recurring" && p.recurring_interval === "month");
}
function getYearlyPrice(product: PolarProduct): PolarPrice | undefined {
  return product.prices.find((p) => p.type === "recurring" && p.recurring_interval === "year");
}
function getOneTimePrice(product: PolarProduct): PolarPrice | undefined {
  return product.prices.find((p) => p.type === "one_time");
}
function getBestPrice(product: PolarProduct): PolarPrice | undefined {
  return getMonthlyPrice(product) ?? getYearlyPrice(product) ?? getOneTimePrice(product) ?? product.prices[0];
}

const sorted = [...products].sort((a, b) => {
  const pa = getBestPrice(a)?.price_amount ?? 0;
  const pb = getBestPrice(b)?.price_amount ?? 0;
  return pa - pb;
});

const isPopular = (i: number) => i === 1 && sorted.length >= 2;

const faqs = [
  { q: "Can I switch plans?", a: "Yes — upgrade or downgrade anytime from your dashboard. Changes take effect immediately." },
  { q: "What happens when I hit my limit?", a: "We'll notify you. Submissions keep working, but you'll need to upgrade to continue beyond the grace period." },
  { q: "Do you offer refunds?", a: "Yes. 14-day money-back guarantee, no questions asked." },
  { q: "Does it work with my website?", a: "If it can render an HTML form, it works with ContactFormAPI. Any framework, any platform." },
];
---

<BaseLayout title="Pricing" description="Simple, transparent pricing for ContactFormAPI.">
  <section class="relative overflow-hidden bg-navy-950 pt-32 pb-20 sm:pt-40 sm:pb-24">
    <div class="absolute inset-0 bg-[linear-gradient(rgba(251,191,36,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(251,191,36,0.03)_1px,transparent_1px)] bg-[size:64px_64px]"></div>
    <div class="relative mx-auto max-w-7xl px-5 sm:px-8 text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-amber-400">Pricing</p>
      <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
        Simple plans that scale with you
      </h1>
      <p class="mx-auto mt-4 max-w-xl text-lg text-slate-400">
        Start free. Upgrade when you're ready. No hidden fees.
      </p>
    </div>
  </section>

  <section class="relative -mt-8 pb-24">
    <div class="mx-auto max-w-7xl px-5 sm:px-8">
      {error && (
        <div class="mx-auto mb-8 max-w-md rounded-xl border border-amber-200 bg-amber-50 p-4 text-center text-sm text-amber-800">
          {error}
        </div>
      )}

      {sorted.length > 0 ? (
        <div class={`mx-auto grid max-w-5xl gap-6 ${
          sorted.length === 1 ? "max-w-md" :
          sorted.length === 2 ? "md:grid-cols-2 max-w-3xl" :
          sorted.length === 3 ? "md:grid-cols-3" :
          "md:grid-cols-2 lg:grid-cols-4"
        }`}>
          {sorted.map((product, i) => {
            const price = getBestPrice(product);
            const pop = isPopular(i);
            return (
              <div class={`relative flex flex-col rounded-2xl border p-8 transition-all duration-300 ${
                pop
                  ? "border-amber-400 bg-white shadow-2xl shadow-amber-200/30 ring-2 ring-amber-400 scale-[1.02]"
                  : "border-slate-200 bg-white hover:border-amber-200 hover:shadow-lg"
              }`}>
                {pop && (
                  <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-gradient-to-r from-amber-500 to-amber-400 px-4 py-1 text-xs font-bold text-navy-950 shadow-lg shadow-amber-400/30">
                    Most Popular
                  </div>
                )}

                <h3 class="text-lg font-bold text-slate-900">{product.name}</h3>
                {product.description && (
                  <p class="mt-1 text-sm text-slate-500">{product.description}</p>
                )}

                <div class="mt-5 mb-6">
                  {price ? (
                    <span class="text-4xl font-extrabold text-slate-900">{formatPrice(price)}</span>
                  ) : (
                    <span class="text-4xl font-extrabold text-slate-900">Free</span>
                  )}
                </div>

                {product.benefits.length > 0 && (
                  <ul class="mb-8 flex-1 space-y-3">
                    {product.benefits.map((b) => (
                      <li class="flex items-start gap-2.5 text-sm text-slate-600">
                        <svg class="mt-0.5 h-4 w-4 shrink-0 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                        </svg>
                        {b.description}
                      </li>
                    ))}
                  </ul>
                )}

                <a
                  href="https://app.contactformapi.com/register"
                  class={`mt-auto inline-flex w-full items-center justify-center rounded-xl px-6 py-3 text-sm font-semibold transition-all ${
                    pop
                      ? "bg-amber-500 text-navy-950 shadow-lg shadow-amber-500/20 hover:bg-amber-400"
                      : "border border-slate-200 bg-white text-slate-700 hover:border-amber-300 hover:bg-amber-50"
                  }`}
                >
                  Get started
                </a>
              </div>
            );
          })}
        </div>
      ) : !error && (
        <p class="text-center text-slate-500 mt-8">Plans are being loaded...</p>
      )}
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-slate-100 bg-slate-50 py-24">
    <div class="mx-auto max-w-3xl px-5 sm:px-8">
      <h2 class="text-center text-2xl font-extrabold text-slate-900">Frequently asked questions</h2>
      <div class="mt-10 space-y-8">
        {faqs.map((f) => (
          <div>
            <h3 class="text-[15px] font-bold text-slate-900">{f.q}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-slate-500">{f.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
