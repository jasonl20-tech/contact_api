---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getProducts, formatPrice, type PolarProduct, type PolarPrice } from "../lib/polar";

export const prerender = true;

let products: PolarProduct[] = [];
let error: string | null = null;

try {
  products = await getProducts();
} catch (e) {
  error = "Plans could not be loaded.";
  console.error("Failed to fetch products:", e);
}

function getBestPrice(p: PolarProduct): PolarPrice | undefined {
  return p.prices.find((x) => x.type === "recurring" && x.recurring_interval === "month")
    ?? p.prices.find((x) => x.type === "recurring" && x.recurring_interval === "year")
    ?? p.prices.find((x) => x.type === "one_time")
    ?? p.prices[0];
}

const sorted = [...products].sort((a, b) => (getBestPrice(a)?.price_amount ?? 0) - (getBestPrice(b)?.price_amount ?? 0));
const isPopular = (i: number) => i === 1 && sorted.length >= 2;

const faqs = [
  { q: "Can I switch plans?", a: "Yes — upgrade or downgrade anytime. Changes take effect immediately." },
  { q: "What happens at the limit?", a: "We notify you. Submissions keep working during a short grace period." },
  { q: "Do you offer refunds?", a: "14-day money-back guarantee, no questions asked." },
  { q: "Does it work with my site?", a: "If it renders HTML forms, it works with ContactFormAPI." },
];
---

<BaseLayout title="Pricing" description="Simple, transparent pricing for ContactFormAPI.">
  <section class="px-3 sm:px-4 pt-20 pb-16 sm:pt-28 sm:pb-20">
    <div class="mx-auto max-w-[1400px]">
      <div class="max-w-xl">
        <p class="text-[13px] font-medium text-brand-600 mb-3">Pricing</p>
        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-900">
          Simple plans,<br />transparent pricing
        </h1>
        <p class="mt-4 text-base text-gray-500">
          Start free. Upgrade when you need more. No hidden fees.
        </p>
      </div>
    </div>
  </section>

  <section class="px-3 sm:px-4 pb-16 sm:pb-24">
    <div class="mx-auto max-w-[1400px]">
      {error && (
        <div class="mb-8 rounded-2xl border border-brand-200 bg-brand-50 p-4 text-sm text-brand-800 max-w-md">
          {error}
        </div>
      )}

      {sorted.length > 0 ? (
        <div class={`grid gap-4 ${
          sorted.length <= 2 ? "md:grid-cols-2 max-w-3xl" :
          sorted.length === 3 ? "md:grid-cols-3" :
          "md:grid-cols-2 lg:grid-cols-4"
        }`}>
          {sorted.map((product, i) => {
            const price = getBestPrice(product);
            const pop = isPopular(i);
            return (
              <div class={`relative flex flex-col rounded-3xl p-7 ${
                pop
                  ? "bg-gray-900 text-white ring-1 ring-gray-900"
                  : "bg-gray-50 border border-gray-100"
              }`}>
                {pop && (
                  <span class="absolute -top-2.5 right-6 rounded-full bg-brand-400 px-3 py-0.5 text-[11px] font-semibold text-gray-900">
                    Popular
                  </span>
                )}

                <h3 class={`text-[15px] font-semibold ${pop ? "text-white" : "text-gray-900"}`}>
                  {product.name}
                </h3>
                {product.description && (
                  <p class={`mt-1 text-[13px] ${pop ? "text-gray-400" : "text-gray-500"}`}>
                    {product.description}
                  </p>
                )}

                <div class="mt-5 mb-6">
                  {price ? (
                    <span class={`text-3xl font-bold ${pop ? "text-white" : "text-gray-900"}`}>
                      {formatPrice(price)}
                    </span>
                  ) : (
                    <span class={`text-3xl font-bold ${pop ? "text-white" : "text-gray-900"}`}>Free</span>
                  )}
                </div>

                {product.benefits.length > 0 && (
                  <ul class="mb-7 flex-1 space-y-2.5">
                    {product.benefits.map((b) => (
                      <li class={`flex items-start gap-2 text-[13px] ${pop ? "text-gray-300" : "text-gray-500"}`}>
                        <svg class={`mt-0.5 h-3.5 w-3.5 shrink-0 ${pop ? "text-brand-400" : "text-brand-500"}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                        </svg>
                        {b.description || b.type || "Included"}
                      </li>
                    ))}
                  </ul>
                )}

                <a
                  href={price?.amount_type === "free" || (price?.price_amount ?? 0) === 0
                    ? "https://app.contactformapi.com/register"
                    : `https://app.contactformapi.com/checkout?product_id=${encodeURIComponent(product.id)}`}
                  class={`mt-auto inline-flex w-full items-center justify-center rounded-full px-5 py-2.5 text-[13px] font-medium transition-colors ${
                    pop
                      ? "bg-white text-gray-900 hover:bg-gray-100"
                      : "bg-gray-900 text-white hover:bg-gray-800"
                  }`}
                >
                  {price?.amount_type === "free" || (price?.price_amount ?? 0) === 0 ? "Get started" : "Subscribe"}
                </a>
              </div>
            );
          })}
        </div>
      ) : !error && (
        <p class="text-gray-400">No subscription plans found in Polar.</p>
      )}
    </div>
  </section>

  <!-- FAQ -->
  <section class="px-3 sm:px-4 pb-16 sm:pb-24">
    <div class="mx-auto max-w-[1400px]">
      <div class="max-w-2xl">
        <h2 class="text-xl font-bold text-gray-900 mb-8">Frequently asked questions</h2>
        <div class="space-y-6">
          {faqs.map((f) => (
            <div class="border-b border-gray-100 pb-6 last:border-0">
              <h3 class="text-[15px] font-semibold text-gray-900">{f.q}</h3>
              <p class="mt-1.5 text-[13px] leading-relaxed text-gray-500">{f.a}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
