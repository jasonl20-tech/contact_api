---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getProducts, formatPrice, type PolarProduct, type PolarPrice } from "../lib/polar";

let products: PolarProduct[] = [];
let error: string | null = null;

try {
  products = await getProducts();
} catch (e) {
  error = "Plans could not be loaded. Please try again later.";
  console.error("Failed to fetch products:", e);
}

function getMonthlyPrice(product: PolarProduct): PolarPrice | undefined {
  return product.prices.find(
    (p) => p.type === "recurring" && p.recurring_interval === "month"
  );
}

function getYearlyPrice(product: PolarProduct): PolarPrice | undefined {
  return product.prices.find(
    (p) => p.type === "recurring" && p.recurring_interval === "year"
  );
}

function getOneTimePrice(product: PolarProduct): PolarPrice | undefined {
  return product.prices.find((p) => p.type === "one_time");
}

function getBestPrice(product: PolarProduct): PolarPrice | undefined {
  return getMonthlyPrice(product) ?? getYearlyPrice(product) ?? getOneTimePrice(product) ?? product.prices[0];
}

const sortedProducts = [...products].sort((a, b) => {
  const priceA = getBestPrice(a)?.price_amount ?? 0;
  const priceB = getBestPrice(b)?.price_amount ?? 0;
  return priceA - priceB;
});

const isPopular = (index: number) => index === 1 && sortedProducts.length >= 2;
---

<BaseLayout title="Pricing" description="Simple, transparent pricing for ContactFormAPI. Start free and scale as you grow.">
  <section class="relative overflow-hidden py-20 sm:py-28">
    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-primary-50/50 to-white"></div>
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h1 class="text-4xl font-extrabold tracking-tight text-surface-900 sm:text-5xl">
          Simple, transparent pricing
        </h1>
        <p class="mt-4 text-lg text-surface-500">
          Start free. Scale as you grow. No hidden fees.
        </p>
      </div>

      {error && (
        <div class="mx-auto mt-10 max-w-md rounded-xl border border-amber-200 bg-amber-50 p-4 text-center text-sm text-amber-800">
          {error}
        </div>
      )}

      {sortedProducts.length > 0 ? (
        <div class={`mx-auto mt-16 grid max-w-5xl gap-8 ${
          sortedProducts.length === 1 ? "max-w-md" :
          sortedProducts.length === 2 ? "md:grid-cols-2 max-w-3xl" :
          sortedProducts.length === 3 ? "md:grid-cols-3" :
          "md:grid-cols-2 lg:grid-cols-4"
        }`}>
          {sortedProducts.map((product, index) => {
            const price = getBestPrice(product);
            const popular = isPopular(index);
            return (
              <div
                class={`relative flex flex-col rounded-2xl border p-8 transition-all hover:shadow-lg ${
                  popular
                    ? "border-primary-600 bg-white shadow-xl shadow-primary-100/50 ring-1 ring-primary-600"
                    : "border-surface-200 bg-white hover:border-primary-200"
                }`}
              >
                {popular && (
                  <div class="absolute -top-3.5 left-1/2 -translate-x-1/2 rounded-full bg-primary-600 px-4 py-1 text-xs font-semibold text-white">
                    Most Popular
                  </div>
                )}

                <div class="mb-6">
                  <h3 class="text-xl font-bold text-surface-900">{product.name}</h3>
                  {product.description && (
                    <p class="mt-2 text-sm text-surface-500">{product.description}</p>
                  )}
                </div>

                <div class="mb-6">
                  {price ? (
                    <div class="flex items-baseline gap-1">
                      <span class="text-4xl font-extrabold text-surface-900">
                        {formatPrice(price)}
                      </span>
                    </div>
                  ) : (
                    <span class="text-4xl font-extrabold text-surface-900">Free</span>
                  )}
                </div>

                {product.benefits.length > 0 && (
                  <ul class="mb-8 flex-1 space-y-3">
                    {product.benefits.map((benefit) => (
                      <li class="flex items-start gap-2 text-sm text-surface-600">
                        <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                        </svg>
                        {benefit.description}
                      </li>
                    ))}
                  </ul>
                )}

                <a
                  href="https://app.contactformapi.com/register"
                  class={`mt-auto inline-flex w-full items-center justify-center rounded-xl px-6 py-3 text-sm font-semibold transition-all ${
                    popular
                      ? "bg-primary-600 text-white shadow-lg shadow-primary-600/25 hover:bg-primary-700"
                      : "border border-surface-300 bg-white text-surface-700 hover:border-surface-400 hover:bg-surface-50"
                  }`}
                >
                  Get started
                </a>
              </div>
            );
          })}
        </div>
      ) : !error && (
        <div class="mx-auto mt-16 max-w-md text-center">
          <p class="text-surface-500">Plans are loading...</p>
        </div>
      )}

      <!-- FAQ -->
      <div class="mx-auto mt-20 max-w-2xl">
        <h2 class="text-center text-2xl font-bold text-surface-900">Frequently asked questions</h2>
        <div class="mt-8 space-y-6">
          <div>
            <h3 class="font-semibold text-surface-900">Can I change plans later?</h3>
            <p class="mt-1 text-sm text-surface-500">Yes. You can upgrade or downgrade your plan at any time from your dashboard.</p>
          </div>
          <div>
            <h3 class="font-semibold text-surface-900">What happens if I exceed my submission limit?</h3>
            <p class="mt-1 text-sm text-surface-500">We'll notify you before you reach your limit. Submissions will still be accepted, but you'll need to upgrade to continue.</p>
          </div>
          <div>
            <h3 class="font-semibold text-surface-900">Do you offer refunds?</h3>
            <p class="mt-1 text-sm text-surface-500">Yes, we offer a 14-day money-back guarantee. No questions asked.</p>
          </div>
          <div>
            <h3 class="font-semibold text-surface-900">Can I use ContactFormAPI with my existing website?</h3>
            <p class="mt-1 text-sm text-surface-500">Absolutely. ContactFormAPI works with any website that can render HTML forms — no matter the platform or framework.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
