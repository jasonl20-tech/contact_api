---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="px-5 pt-20 pb-16 sm:pt-28 sm:pb-20">
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-[13px] font-medium text-brand-600 mb-4">Form Backend as a Service</p>
        <h1 class="text-[clamp(2.25rem,5vw,3.75rem)] font-bold leading-[1.1] tracking-tight text-gray-900">
          Where Forms<br />Get Delivered
        </h1>
        <p class="mt-5 text-base leading-relaxed text-gray-500 max-w-md mx-auto">
          A simple API that handles your contact form submissions, spam filtering, and email delivery. No backend code required.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3">
          <a href="https://app.contactformapi.com/register" class="w-full sm:w-auto rounded-full bg-gray-900 px-6 py-2.5 text-sm font-medium text-white hover:bg-gray-800 transition-colors text-center">
            Try it free
          </a>
          <a href="#features" class="w-full sm:w-auto rounded-full border border-gray-200 bg-white px-6 py-2.5 text-sm font-medium text-gray-700 hover:border-gray-300 transition-colors text-center">
            Learn more
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- What is ContactFormAPI + Code -->
  <section class="px-5 pb-16 sm:pb-24">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-4 md:grid-cols-2">
        <!-- Left: Text card -->
        <div class="rounded-3xl bg-gray-50 p-8 sm:p-10 flex flex-col justify-between">
          <div>
            <h2 class="text-2xl sm:text-3xl font-bold leading-tight text-gray-900">
              What is ContactFormAPI?
            </h2>
            <p class="mt-4 text-[15px] leading-relaxed text-gray-500">
              ContactFormAPI is a form backend that collects submissions from your HTML forms and delivers them via email, Slack, webhooks, or our dashboard. No servers, no databases — just a URL.
            </p>
          </div>
          <a href="#how-it-works" class="mt-6 inline-flex items-center self-start rounded-full border border-gray-200 px-4 py-2 text-[13px] font-medium text-gray-700 hover:border-gray-300 transition-colors">
            Explore more
          </a>
        </div>

        <!-- Right: Code card -->
        <div class="rounded-3xl bg-gray-900 p-6 sm:p-8 overflow-hidden">
          <p class="text-[11px] font-mono font-medium text-gray-500 uppercase tracking-wider mb-4">contact.html</p>
          <pre class="text-[13px] leading-relaxed font-mono overflow-x-auto"><code><span class="text-gray-500">&lt;</span><span class="text-brand-400">form</span> <span class="text-gray-300">action</span><span class="text-gray-600">=</span><span class="text-green-400">"https://api.contactformapi.com/f/ID"</span>
      <span class="text-gray-300">method</span><span class="text-gray-600">=</span><span class="text-green-400">"POST"</span><span class="text-gray-500">&gt;</span>

  <span class="text-gray-500">&lt;</span><span class="text-brand-400">input</span>
    <span class="text-gray-300">type</span><span class="text-gray-600">=</span><span class="text-green-400">"email"</span>
    <span class="text-gray-300">name</span><span class="text-gray-600">=</span><span class="text-green-400">"email"</span>
    <span class="text-gray-300">required</span>
  <span class="text-gray-500">/&gt;</span>

  <span class="text-gray-500">&lt;</span><span class="text-brand-400">textarea</span>
    <span class="text-gray-300">name</span><span class="text-gray-600">=</span><span class="text-green-400">"message"</span>
  <span class="text-gray-500">&gt;&lt;/</span><span class="text-brand-400">textarea</span><span class="text-gray-500">&gt;</span>

  <span class="text-gray-500">&lt;</span><span class="text-brand-400">button</span> <span class="text-gray-300">type</span><span class="text-gray-600">=</span><span class="text-green-400">"submit"</span><span class="text-gray-500">&gt;</span>
    <span class="text-white">Send</span>
  <span class="text-gray-500">&lt;/</span><span class="text-brand-400">button</span><span class="text-gray-500">&gt;</span>

<span class="text-gray-500">&lt;/</span><span class="text-brand-400">form</span><span class="text-gray-500">&gt;</span></code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature cards grid (like USD Bloom) -->
  <section id="features" class="px-5 pb-16 sm:pb-24">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <!-- Card 1 -->
        <div class="rounded-3xl bg-brand-50 border border-brand-100 p-7">
          <div class="mb-4 inline-flex rounded-2xl bg-white p-2.5 shadow-sm">
            <svg class="h-5 w-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
          </div>
          <h3 class="text-[15px] font-semibold text-gray-900">Form to Email</h3>
          <p class="mt-1.5 text-[13px] leading-relaxed text-gray-500">
            Every submission goes directly to your inbox. Customize templates, redirect URLs, and more.
          </p>
        </div>

        <!-- Card 2 -->
        <div class="rounded-3xl bg-gray-50 border border-gray-100 p-7">
          <div class="mb-4 inline-flex rounded-2xl bg-white p-2.5 shadow-sm">
            <svg class="h-5 w-5 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" />
            </svg>
          </div>
          <h3 class="text-[15px] font-semibold text-gray-900">Zero backend</h3>
          <p class="mt-1.5 text-[13px] leading-relaxed text-gray-500">
            Just set the form action to our URL. Works with any HTML, any framework, any static site.
          </p>
        </div>

        <!-- Card 3 -->
        <div class="rounded-3xl bg-gray-50 border border-gray-100 p-7">
          <div class="mb-4 inline-flex rounded-2xl bg-white p-2.5 shadow-sm">
            <svg class="h-5 w-5 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
            </svg>
          </div>
          <h3 class="text-[15px] font-semibold text-gray-900">100% spam-free</h3>
          <p class="mt-1.5 text-[13px] leading-relaxed text-gray-500">
            Built-in support for Turnstile, reCAPTCHA, hCaptcha. No bots make it through.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Platforms strip -->
  <section class="px-5 pb-16 sm:pb-24">
    <div class="mx-auto max-w-6xl">
      <div class="rounded-3xl bg-gray-50 border border-gray-100 px-8 py-6">
        <p class="text-[11px] font-medium uppercase tracking-widest text-gray-400 mb-4">Supported by these tools and more</p>
        <div class="flex flex-wrap gap-3">
          {["HTML", "React", "Next.js", "Vue", "Nuxt", "Svelte", "Astro", "WordPress", "Webflow", "Framer"].map((p) => (
            <span class="rounded-full bg-white border border-gray-200 px-3.5 py-1 text-[12px] font-medium text-gray-600">
              {p}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section id="how-it-works" class="px-5 pb-16 sm:pb-24">
    <div class="mx-auto max-w-6xl">
      <p class="text-[13px] font-medium text-brand-600 mb-3">How it works</p>
      <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-10">
        Set up in 60 seconds
      </h2>

      <div class="grid gap-4 md:grid-cols-3">
        <div class="rounded-3xl border border-gray-100 bg-white p-7">
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-brand-100 text-[13px] font-bold text-brand-700">1</span>
          <h3 class="mt-4 text-[15px] font-semibold text-gray-900">Create endpoint</h3>
          <p class="mt-1.5 text-[13px] leading-relaxed text-gray-500">Sign up and create a form. You get a unique URL instantly.</p>
        </div>
        <div class="rounded-3xl border border-gray-100 bg-white p-7">
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-brand-100 text-[13px] font-bold text-brand-700">2</span>
          <h3 class="mt-4 text-[15px] font-semibold text-gray-900">Point your form</h3>
          <p class="mt-1.5 text-[13px] leading-relaxed text-gray-500">Set your form's action attribute. No JavaScript, no SDK.</p>
        </div>
        <div class="rounded-3xl border border-gray-100 bg-white p-7">
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-brand-100 text-[13px] font-bold text-brand-700">3</span>
          <h3 class="mt-4 text-[15px] font-semibold text-gray-900">Get submissions</h3>
          <p class="mt-1.5 text-[13px] leading-relaxed text-gray-500">Receive via email, Slack, webhooks, or export from the dashboard.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- More features grid -->
  <section class="px-5 pb-16 sm:pb-24">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-4 md:grid-cols-2">
        <div class="rounded-3xl border border-gray-100 bg-white p-7">
          <div class="mb-4 inline-flex rounded-2xl bg-gray-50 p-2.5">
            <svg class="h-5 w-5 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />
            </svg>
          </div>
          <h3 class="text-[15px] font-semibold text-gray-900">Webhooks & Integrations</h3>
          <p class="mt-1.5 text-[13px] leading-relaxed text-gray-500">
            Connect to Slack, Zapier, Make, or your own webhooks. Automate workflows with every submission.
          </p>
        </div>

        <div class="rounded-3xl border border-gray-100 bg-white p-7">
          <div class="mb-4 inline-flex rounded-2xl bg-gray-50 p-2.5">
            <svg class="h-5 w-5 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6" />
            </svg>
          </div>
          <h3 class="text-[15px] font-semibold text-gray-900">Dashboard & Analytics</h3>
          <p class="mt-1.5 text-[13px] leading-relaxed text-gray-500">
            Track all submissions, spot trends, and export data as CSV or JSON. Everything in one place.
          </p>
        </div>

        <div class="rounded-3xl border border-gray-100 bg-white p-7">
          <div class="mb-4 inline-flex rounded-2xl bg-gray-50 p-2.5">
            <svg class="h-5 w-5 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
            </svg>
          </div>
          <h3 class="text-[15px] font-semibold text-gray-900">Team Workspaces</h3>
          <p class="mt-1.5 text-[13px] leading-relaxed text-gray-500">
            Invite members, manage permissions, share form endpoints across your organization.
          </p>
        </div>

        <div class="rounded-3xl border border-gray-100 bg-white p-7">
          <div class="mb-4 inline-flex rounded-2xl bg-gray-50 p-2.5">
            <svg class="h-5 w-5 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
            </svg>
          </div>
          <h3 class="text-[15px] font-semibold text-gray-900">File Uploads</h3>
          <p class="mt-1.5 text-[13px] leading-relaxed text-gray-500">
            Accept file attachments through your forms. Documents, images — delivered alongside submissions.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="px-5 pb-16 sm:pb-24">
    <div class="mx-auto max-w-6xl">
      <div class="rounded-3xl bg-gray-900 p-10 sm:p-14 text-center">
        <h2 class="text-2xl sm:text-3xl font-bold text-white">
          Ready to stop building form backends?
        </h2>
        <p class="mt-3 text-[15px] text-gray-400 max-w-md mx-auto">
          Free plan included. Set up in under 60 seconds. No credit card required.
        </p>
        <a
          href="https://app.contactformapi.com/register"
          class="mt-7 inline-flex rounded-full bg-white px-6 py-2.5 text-sm font-medium text-gray-900 hover:bg-gray-100 transition-colors"
        >
          Get started free
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
