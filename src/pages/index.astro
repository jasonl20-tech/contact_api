---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Home">
  <!-- ============ HERO (video background + centered text overlay) ============ -->
  <section class="relative pt-14">
    <div class="relative mx-auto max-w-[1400px] px-3 sm:px-4">
      <div class="relative overflow-hidden rounded-b-[2rem]">
        <!-- Video background -->
        <video
          autoplay
          loop
          muted
          playsinline
          class="absolute inset-0 w-full h-full object-cover"
        >
          <source src="/ContactFormAPI.mp4" type="video/mp4" />
        </video>

        <!-- Text overlay -->
        <div class="relative flex flex-col items-center px-6 pt-20 pb-28 sm:pt-28 sm:pb-36 text-center">
          <span class="mb-5 text-amber-700/60 text-lg">+</span>
          <h1 class="text-[clamp(2rem,5.5vw,3.5rem)] font-bold leading-[1.1] tracking-[-0.02em] text-gray-900">
            Where Forms<br />Get Delivered
          </h1>
          <p class="mt-4 max-w-sm text-[14px] leading-relaxed text-gray-500">
            A simple, reliable form backend designed for seamless integration into any website.
          </p>
          <a
            href="https://app.contactformapi.com/register"
            class="mt-7 rounded-full bg-gray-900 px-6 py-2.5 text-[13px] font-medium text-white hover:bg-gray-800 transition-colors"
          >
            Try it now
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ WHAT IS (2-col: heading left, text right) ============ -->
  <section id="product" class="px-3 sm:px-4 pt-20 pb-14 sm:pt-28 sm:pb-20">
    <div class="mx-auto max-w-[1400px]">
      <div class="grid gap-10 md:grid-cols-2 items-start">
        <!-- Left -->
        <div>
          <h2 class="text-[clamp(1.75rem,4vw,2.75rem)] font-bold leading-[1.15] tracking-[-0.02em] text-gray-900">
            What is<br />ContactFormAPI?
          </h2>
          <a
            href="#features"
            class="mt-6 inline-flex rounded-full bg-gray-900 px-5 py-2 text-[13px] font-medium text-white hover:bg-gray-800 transition-colors"
          >
            Explore now
          </a>
        </div>
        <!-- Right -->
        <div class="md:pt-2">
          <p class="text-[15px] leading-[1.7] text-gray-500">
            ContactFormAPI is a form backend service that collects your HTML form submissions and delivers them via email, Slack, or webhooks. It handles spam filtering, file uploads, and notifications — so you never need to build a form backend again.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ 3 FEATURE CARDS (colored bg, matching USD Bloom) ============ -->
  <section id="features" class="px-3 sm:px-4 pb-14 sm:pb-20">
    <div class="mx-auto max-w-[1400px]">
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        <!-- Card 1 -->
        <div class="relative overflow-hidden rounded-[1.5rem] bg-gradient-to-b from-amber-100/80 to-amber-50 p-7 pb-10 min-h-[260px]">
          <h3 class="text-[17px] font-semibold text-gray-900 leading-snug">
            Submissions<br />that arrive
          </h3>
          <p class="mt-2 text-[13px] leading-relaxed text-gray-500 max-w-[220px]">
            Every form submission delivered to your inbox, Slack, or webhook — reliably, every time.
          </p>
          <div class="absolute -bottom-6 -right-6 h-28 w-28 rounded-full bg-amber-200/50 blur-xl"></div>
        </div>

        <!-- Card 2 -->
        <div class="relative overflow-hidden rounded-[1.5rem] bg-gradient-to-b from-orange-100/60 to-orange-50/40 p-7 pb-10 min-h-[260px]">
          <h3 class="text-[17px] font-semibold text-gray-900 leading-snug">
            Always secure,<br />always filtered
          </h3>
          <p class="mt-2 text-[13px] leading-relaxed text-gray-500 max-w-[220px]">
            Built-in spam protection with Turnstile, reCAPTCHA, hCaptcha. Keep your inbox clean.
          </p>
          <div class="absolute -bottom-6 -right-6 h-28 w-28 rounded-full bg-orange-200/50 blur-xl"></div>
        </div>

        <!-- Card 3 -->
        <div class="relative overflow-hidden rounded-[1.5rem] bg-gradient-to-b from-yellow-100/60 to-yellow-50/30 p-7 pb-10 min-h-[260px]">
          <h3 class="text-[17px] font-semibold text-gray-900 leading-snug">
            100%<br />hands-free
          </h3>
          <p class="mt-2 text-[13px] leading-relaxed text-gray-500 max-w-[220px]">
            No servers to manage, no databases to handle. Just a URL that collects your form data.
          </p>
          <div class="absolute -bottom-6 -right-6 h-28 w-28 rounded-full bg-yellow-200/40 blur-xl"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ PLATFORM LOGOS STRIP ============ -->
  <section id="integrations" class="px-3 sm:px-4 pb-14 sm:pb-20">
    <div class="mx-auto max-w-[1400px]">
      <p class="text-[13px] text-gray-400 mb-5">
        Supported by the best frameworks<br class="sm:hidden" /> and trusted by developers everywhere.
      </p>
      <div class="flex flex-wrap items-center gap-x-8 gap-y-3">
        {["React", "Next.js", "Vue", "Svelte", "Astro", "WordPress", "Webflow", "Framer", "Nuxt", "Hugo"].map((name) => (
          <span class="text-[13px] font-medium text-gray-300 hover:text-gray-500 transition-colors cursor-default">
            {name}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ USE CASES (asymmetric: text left, card right) ============ -->
  <section class="px-3 sm:px-4 pb-16 sm:pb-24">
    <div class="mx-auto max-w-[1400px]">
      <div class="mb-4">
        <p class="text-[12px] font-medium uppercase tracking-widest text-gray-400 mb-2">ContactFormAPI in Action</p>
        <h2 class="text-[clamp(1.75rem,4vw,2.75rem)] font-bold leading-[1.15] tracking-[-0.02em] text-gray-900">
          Use cases
        </h2>
      </div>

      <div class="grid gap-4 md:grid-cols-2 mt-8">
        <!-- Left: text info -->
        <div class="flex flex-col justify-center">
          <p class="text-[15px] leading-[1.7] text-gray-500 max-w-sm">
            ContactFormAPI works for a variety of use cases — agencies, freelancers, and businesses that need reliable, secure form collection without writing backend code.
          </p>
        </div>

        <!-- Right: Card -->
        <div class="rounded-[1.5rem] border border-gray-100 bg-white p-8">
          <h3 class="text-[20px] font-semibold text-gray-900 mb-3">Agencies</h3>
          <p class="text-[14px] leading-relaxed text-gray-500 mb-5">
            Ship client sites faster by adding form handling in seconds. Create separate endpoints for each client. Monitor submissions from one dashboard.
          </p>
          <a href="/pricing" class="inline-flex items-center gap-1.5 text-[13px] font-medium text-gray-900 hover:text-amber-700 transition-colors">
            <span class="flex h-5 w-5 items-center justify-center rounded-full bg-gray-100 text-[11px]">+</span>
            Learn more
          </a>
        </div>
      </div>

      <div class="grid gap-4 md:grid-cols-2 mt-4">
        <!-- Card left -->
        <div class="rounded-[1.5rem] border border-gray-100 bg-white p-8">
          <h3 class="text-[20px] font-semibold text-gray-900 mb-3">SaaS & Startups</h3>
          <p class="text-[14px] leading-relaxed text-gray-500 mb-5">
            Add contact forms, feedback forms, and waitlists to your landing pages. Get notified instantly via Slack or email when leads come in.
          </p>
          <a href="/pricing" class="inline-flex items-center gap-1.5 text-[13px] font-medium text-gray-900 hover:text-amber-700 transition-colors">
            <span class="flex h-5 w-5 items-center justify-center rounded-full bg-gray-100 text-[11px]">+</span>
            Learn more
          </a>
        </div>

        <!-- Card right -->
        <div class="rounded-[1.5rem] border border-gray-100 bg-white p-8">
          <h3 class="text-[20px] font-semibold text-gray-900 mb-3">Developers</h3>
          <p class="text-[14px] leading-relaxed text-gray-500 mb-5">
            Use our API for custom integrations. Webhooks, AJAX submissions, file uploads — everything you need with clean documentation.
          </p>
          <a href="/docs" class="inline-flex items-center gap-1.5 text-[13px] font-medium text-gray-900 hover:text-amber-700 transition-colors">
            <span class="flex h-5 w-5 items-center justify-center rounded-full bg-gray-100 text-[11px]">+</span>
            Read docs
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ CODE EXAMPLE ============ -->
  <section class="px-3 sm:px-4 pb-16 sm:pb-24">
    <div class="mx-auto max-w-[1400px]">
      <div class="grid gap-4 md:grid-cols-2">
        <div class="flex flex-col justify-center">
          <p class="text-[12px] font-medium uppercase tracking-widest text-gray-400 mb-2">Integration</p>
          <h2 class="text-[clamp(1.5rem,3vw,2.25rem)] font-bold leading-[1.15] tracking-[-0.02em] text-gray-900 mb-4">
            Two lines of code.<br />That's all.
          </h2>
          <p class="text-[14px] leading-relaxed text-gray-500 max-w-sm">
            Set your form's action attribute to your endpoint URL. No JavaScript SDK, no build step, no dependencies. Just HTML.
          </p>
        </div>

        <div class="rounded-[1.5rem] bg-gray-950 p-6 overflow-hidden">
          <p class="text-[11px] font-mono text-gray-600 uppercase tracking-wider mb-4">contact.html</p>
          <pre class="text-[13px] leading-[1.8] font-mono overflow-x-auto"><code><span class="text-gray-600">&lt;</span><span class="text-amber-400">form</span>
  <span class="text-gray-400">action</span><span class="text-gray-600">=</span><span class="text-emerald-400">"https://api.contactformapi.com/f/ID"</span>
  <span class="text-gray-400">method</span><span class="text-gray-600">=</span><span class="text-emerald-400">"POST"</span><span class="text-gray-600">&gt;</span>

  <span class="text-gray-600">&lt;</span><span class="text-amber-400">input</span> <span class="text-gray-400">type</span><span class="text-gray-600">=</span><span class="text-emerald-400">"email"</span> <span class="text-gray-400">name</span><span class="text-gray-600">=</span><span class="text-emerald-400">"email"</span> <span class="text-gray-600">/&gt;</span>
  <span class="text-gray-600">&lt;</span><span class="text-amber-400">textarea</span> <span class="text-gray-400">name</span><span class="text-gray-600">=</span><span class="text-emerald-400">"message"</span><span class="text-gray-600">&gt;&lt;/</span><span class="text-amber-400">textarea</span><span class="text-gray-600">&gt;</span>
  <span class="text-gray-600">&lt;</span><span class="text-amber-400">button</span><span class="text-gray-600">&gt;</span><span class="text-white">Send</span><span class="text-gray-600">&lt;/</span><span class="text-amber-400">button</span><span class="text-gray-600">&gt;</span>

<span class="text-gray-600">&lt;/</span><span class="text-amber-400">form</span><span class="text-gray-600">&gt;</span></code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="px-3 sm:px-4 pb-16 sm:pb-24">
    <div class="mx-auto max-w-[1400px]">
      <div class="rounded-[1.5rem] bg-gradient-to-br from-amber-50 to-orange-50 p-10 sm:p-14 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
        <div>
          <h2 class="text-[22px] sm:text-[26px] font-bold text-gray-900 tracking-[-0.01em]">
            Start collecting submissions today
          </h2>
          <p class="mt-1.5 text-[14px] text-gray-500">Free plan included. No credit card required.</p>
        </div>
        <a
          href="https://app.contactformapi.com/register"
          class="shrink-0 rounded-full bg-gray-900 px-6 py-2.5 text-[13px] font-medium text-white hover:bg-gray-800 transition-colors"
        >
          Get started free
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
