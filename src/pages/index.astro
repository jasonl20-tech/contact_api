---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Home">
  <!-- ============ HERO (full-width visual + centered text) ============ -->
  <section class="relative pt-14">
    <div class="relative mx-auto max-w-[1400px] px-3 sm:px-4">
      <div class="relative overflow-hidden rounded-b-[2rem] bg-gradient-to-b from-amber-50 via-orange-50 to-amber-100">
        <!-- Decorative shapes -->
        <div class="absolute top-12 left-1/2 -translate-x-1/2 h-[300px] w-[500px] rounded-full bg-amber-200/30 blur-[80px]"></div>
        <div class="absolute -bottom-20 -left-20 h-40 w-40 rounded-full bg-amber-300/20 blur-3xl"></div>
        <div class="absolute -bottom-10 -right-10 h-32 w-32 rounded-full bg-orange-200/30 blur-3xl"></div>

        <div class="relative flex flex-col items-center px-6 pt-20 pb-28 sm:pt-28 sm:pb-36 text-center">
          <span class="mb-5 text-amber-700/60 text-lg">+</span>
          <h1 class="text-[clamp(2rem,5.5vw,3.5rem)] font-bold leading-[1.1] tracking-[-0.02em] text-gray-900">
            Where Forms<br />Get Delivered
          </h1>

          <!-- Rotating "To [Integration]" -->
          <div class="mt-4 flex items-center gap-2.5 h-8 overflow-hidden">
            <span class="text-[15px] text-gray-400">To</span>
            <div id="integration-rotator" class="relative h-8 flex items-center">
              <div class="flex items-center gap-2 transition-all duration-500" id="rotator-inner">
                <!-- Filled by JS -->
              </div>
            </div>
          </div>

          <p class="mt-4 max-w-sm text-[14px] leading-relaxed text-gray-500">
            A simple, reliable form backend designed for seamless integration into any website.
          </p>
          <a
            href="https://app.contactformapi.com/register"
            class="mt-7 rounded-full bg-gray-900 px-6 py-2.5 text-[13px] font-medium text-white hover:bg-gray-800 transition-colors"
          >
            Try it now
          </a>
        </div>

        <script>
          const integrations = [
            { name: "Slack", color: "#611f69", svg: `<svg viewBox="0 0 24 24" fill="none" class="h-5 w-5"><path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zm1.271 0a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313z" fill="#E01E5A"/><path d="M8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zm0 1.271a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312z" fill="#36C5F0"/><path d="M18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zm-1.27 0a2.528 2.528 0 0 1-2.522 2.521 2.528 2.528 0 0 1-2.52-2.521V2.522A2.528 2.528 0 0 1 15.165 0a2.528 2.528 0 0 1 2.521 2.522v6.312z" fill="#2EB67D"/><path d="M15.165 18.956a2.528 2.528 0 0 1 2.521 2.522A2.528 2.528 0 0 1 15.165 24a2.527 2.527 0 0 1-2.52-2.522v-2.522h2.52zm0-1.27a2.527 2.527 0 0 1-2.52-2.522 2.527 2.527 0 0 1 2.52-2.52h6.313A2.528 2.528 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.521h-6.313z" fill="#ECB22E"/></svg>` },
            { name: "Discord", color: "#5865F2", svg: `<svg viewBox="0 0 24 24" fill="#5865F2" class="h-5 w-5"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>` },
            { name: "Email", color: "#EA4335", svg: `<svg viewBox="0 0 24 24" fill="none" stroke="#EA4335" stroke-width="1.5" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0-8.953 5.468a1.5 1.5 0 0 1-1.594 0L2.25 6.75"/></svg>` },
            { name: "Notion", color: "#000000", svg: `<svg viewBox="0 0 24 24" fill="#000" class="h-5 w-5"><path d="M4.459 4.208c.746.606 1.026.56 2.428.466l13.215-.793c.28 0 .047-.28-.046-.326L18.29 2.168c-.42-.326-.98-.7-2.055-.607L3.01 2.721c-.466.046-.56.28-.374.466l1.823 1.02zm.793 3.358v13.905c0 .746.373 1.026 1.213.98l14.523-.839c.84-.046.933-.56.933-1.166V6.63c0-.606-.233-.933-.746-.886l-15.177.886c-.56.047-.746.327-.746.933zm14.337.699c.093.42 0 .84-.42.886l-.699.14v10.265c-.607.327-1.166.513-1.632.513-.746 0-.933-.233-1.493-.933l-4.571-7.179v6.94l1.446.326s0 .84-1.166.84l-3.218.187c-.093-.187 0-.653.327-.746l.84-.233V9.855L7.362 9.71c-.093-.42.14-1.026.793-1.073l3.451-.233 4.758 7.272v-6.43l-1.213-.14c-.093-.513.28-.886.746-.933l3.451-.187z"/></svg>` },
            { name: "Google Sheets", color: "#34A853", svg: `<svg viewBox="0 0 24 24" fill="#34A853" class="h-5 w-5"><path d="M19.385 2H4.615A2.615 2.615 0 0 0 2 4.615v14.77A2.615 2.615 0 0 0 4.615 22h14.77A2.615 2.615 0 0 0 22 19.385V4.615A2.615 2.615 0 0 0 19.385 2zM7 17.5v-2h3v2H7zm0-3.5v-2h3v2H7zm0-3.5v-2h3v2H7zM17 17.5h-5v-2h5v2zm0-3.5h-5v-2h5v2zm0-3.5h-5v-2h5v2z"/></svg>` },
            { name: "Webhooks", color: "#525252", svg: `<svg viewBox="0 0 24 24" fill="none" stroke="#525252" stroke-width="1.5" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m9.86-3.06a4.5 4.5 0 0 0-1.242-7.244l-4.5-4.5a4.5 4.5 0 1 0-6.364 6.364L5.25 8.81"/></svg>` },
            { name: "Zapier", color: "#FF4A00", svg: `<svg viewBox="0 0 24 24" fill="#FF4A00" class="h-5 w-5"><path d="M15.535 8.465l-1.263 1.263A4.992 4.992 0 0 0 13 9.07V7.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.57a4.992 4.992 0 0 0-1.272.658l-1.263-1.263a.5.5 0 0 0-.707 0l-.707.707a.5.5 0 0 0 0 .707l1.263 1.263A4.992 4.992 0 0 0 7.57 12.5H6a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 .5.5h1.57a4.992 4.992 0 0 0 .658 1.272l-1.263 1.263a.5.5 0 0 0 0 .707l.707.707a.5.5 0 0 0 .707 0l1.263-1.263a4.992 4.992 0 0 0 1.272.658V18.5a.5.5 0 0 0 .5.5h1a.5.5 0 0 0 .5-.5v-1.57a4.992 4.992 0 0 0 1.272-.658l1.263 1.263a.5.5 0 0 0 .707 0l.707-.707a.5.5 0 0 0 0-.707l-1.263-1.263a4.993 4.993 0 0 0 .658-1.272H18a.5.5 0 0 0 .5-.5v-1a.5.5 0 0 0-.5-.5h-1.57a4.992 4.992 0 0 0-.658-1.272l1.263-1.263a.5.5 0 0 0 0-.707l-.707-.707a.5.5 0 0 0-.707 0zM12 15a2 2 0 1 1 0-4 2 2 0 0 1 0 4z"/></svg>` },
            { name: "Make", color: "#6D00CC", svg: `<svg viewBox="0 0 24 24" fill="#6D00CC" class="h-5 w-5"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4" fill="white"/></svg>` },
            { name: "n8n", color: "#EA4B71", svg: `<svg viewBox="0 0 24 24" fill="none" class="h-5 w-5"><rect x="2" y="8" width="7" height="7" rx="1.5" fill="#EA4B71"/><rect x="15" y="8" width="7" height="7" rx="1.5" fill="#EA4B71"/><path d="M9 11.5h6" stroke="#EA4B71" stroke-width="2" stroke-linecap="round"/></svg>` },
            { name: "Airtable", color: "#18BFFF", svg: `<svg viewBox="0 0 24 24" fill="#18BFFF" class="h-5 w-5"><path d="M11.5 2.3L3.44 5.36a.89.89 0 0 0 0 1.66l8.1 3.09a2.22 2.22 0 0 0 1.58 0l8.1-3.09a.89.89 0 0 0 0-1.66L13.14 2.3a2.22 2.22 0 0 0-1.64 0z"/><path d="M12.66 12.2v8.46c0 .6.63 1 1.18.76l8.49-3.56c.33-.14.55-.47.55-.84V8.56c0-.6-.63-1-1.18-.76l-8.49 3.56a.89.89 0 0 0-.55.84z"/><path d="M11.34 12.2v8.46c0 .6-.63 1-1.18.76L1.67 17.86a.89.89 0 0 1-.55-.84V8.56c0-.6.63-1 1.18-.76l8.49 3.56c.33.14.55.47.55.84z" opacity=".7"/></svg>` },
            { name: "Telegram", color: "#26A5E4", svg: `<svg viewBox="0 0 24 24" fill="#26A5E4" class="h-5 w-5"><path d="M11.944 0A12 12 0 1 0 24 12.056A12.013 12.013 0 0 0 11.944 0zm5.654 8.22l-1.636 7.706c-.12.54-.44.67-.892.418l-2.461-1.814-1.188 1.143c-.132.131-.242.242-.496.242l.177-2.507 4.563-4.122c.198-.177-.043-.275-.308-.098l-5.64 3.549-2.429-.757c-.528-.165-.539-.528.11-.782l9.494-3.66c.44-.159.826.108.682.782z"/></svg>` },
            { name: "Microsoft Teams", color: "#6264A7", svg: `<svg viewBox="0 0 24 24" fill="#6264A7" class="h-5 w-5"><path d="M20.625 8.5h-3.25v6.25a3.25 3.25 0 0 1-3.25 3.25H9.5v.375A1.625 1.625 0 0 0 11.125 20h6.25l2.875 2V20h.375A1.625 1.625 0 0 0 22.25 18.375v-8.25A1.625 1.625 0 0 0 20.625 8.5z"/><path d="M14.125 4H3.875A1.625 1.625 0 0 0 2.25 5.625v8.25A1.625 1.625 0 0 0 3.875 15.5h.375v3.5L7.125 15.5h7A1.625 1.625 0 0 0 15.75 13.875V5.625A1.625 1.625 0 0 0 14.125 4z"/><circle cx="19" cy="5.5" r="2.5"/></svg>` },
          ];
          const inner = document.getElementById('rotator-inner');
          if (inner) {
            let idx = 0;
            function render() {
              const item = integrations[idx];
              inner.style.opacity = '0';
              inner.style.transform = 'translateY(8px)';
              setTimeout(() => {
                inner.innerHTML = item.svg + '<span style="color:' + item.color + ';font-weight:600;font-size:15px;">' + item.name + '</span>';
                inner.style.opacity = '1';
                inner.style.transform = 'translateY(0)';
              }, 300);
              idx = (idx + 1) % integrations.length;
            }
            render();
            setInterval(render, 2200);
          }
        </script>
      </div>
    </div>
  </section>

  <!-- ============ WHAT IS (2-col: heading left, text right) ============ -->
  <section id="product" class="px-3 sm:px-4 pt-20 pb-14 sm:pt-28 sm:pb-20">
    <div class="mx-auto max-w-[1400px]">
      <div class="grid gap-10 md:grid-cols-2 items-start">
        <!-- Left -->
        <div>
          <h2 class="text-[clamp(1.75rem,4vw,2.75rem)] font-bold leading-[1.15] tracking-[-0.02em] text-gray-900">
            What is<br />ContactFormAPI?
          </h2>
          <a
            href="#features"
            class="mt-6 inline-flex rounded-full bg-gray-900 px-5 py-2 text-[13px] font-medium text-white hover:bg-gray-800 transition-colors"
          >
            Explore now
          </a>
        </div>
        <!-- Right -->
        <div class="md:pt-2">
          <p class="text-[15px] leading-[1.7] text-gray-500">
            ContactFormAPI collects your HTML form submissions and delivers them to 20+ integrations — Email, Slack, Discord, Notion, Google Sheets, Zapier, HubSpot, Telegram, and many more. It handles spam filtering, file uploads, and notifications — so you never need to build a form backend again.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ 3 FEATURE CARDS (colored bg, matching USD Bloom) ============ -->
  <section id="features" class="px-3 sm:px-4 pb-14 sm:pb-20">
    <div class="mx-auto max-w-[1400px]">
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        <!-- Card 1 -->
        <div class="relative overflow-hidden rounded-[1.5rem] bg-gradient-to-b from-amber-100/80 to-amber-50 p-7 pb-10 min-h-[260px]">
          <h3 class="text-[17px] font-semibold text-gray-900 leading-snug">
            Submissions<br />that arrive
          </h3>
          <p class="mt-2 text-[13px] leading-relaxed text-gray-500 max-w-[220px]">
            Every form submission delivered to your inbox, Slack, or webhook — reliably, every time.
          </p>
          <div class="absolute -bottom-6 -right-6 h-28 w-28 rounded-full bg-amber-200/50 blur-xl"></div>
        </div>

        <!-- Card 2 -->
        <div class="relative overflow-hidden rounded-[1.5rem] bg-gradient-to-b from-orange-100/60 to-orange-50/40 p-7 pb-10 min-h-[260px]">
          <h3 class="text-[17px] font-semibold text-gray-900 leading-snug">
            Always secure,<br />always filtered
          </h3>
          <p class="mt-2 text-[13px] leading-relaxed text-gray-500 max-w-[220px]">
            Built-in spam protection with Turnstile, reCAPTCHA, hCaptcha. Keep your inbox clean.
          </p>
          <div class="absolute -bottom-6 -right-6 h-28 w-28 rounded-full bg-orange-200/50 blur-xl"></div>
        </div>

        <!-- Card 3 -->
        <div class="relative overflow-hidden rounded-[1.5rem] bg-gradient-to-b from-yellow-100/60 to-yellow-50/30 p-7 pb-10 min-h-[260px]">
          <h3 class="text-[17px] font-semibold text-gray-900 leading-snug">
            100%<br />hands-free
          </h3>
          <p class="mt-2 text-[13px] leading-relaxed text-gray-500 max-w-[220px]">
            No servers to manage, no databases to handle. Just a URL that collects your form data.
          </p>
          <div class="absolute -bottom-6 -right-6 h-28 w-28 rounded-full bg-yellow-200/40 blur-xl"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ INTEGRATIONS ============ -->
  <section id="integrations" class="px-3 sm:px-4 pb-16 sm:pb-24">
    <div class="mx-auto max-w-[1400px]">
      <div class="mb-10">
        <p class="text-[12px] font-medium uppercase tracking-widest text-gray-400 mb-2">Integrations</p>
        <h2 class="text-[clamp(1.75rem,4vw,2.75rem)] font-bold leading-[1.15] tracking-[-0.02em] text-gray-900">
          Deliver submissions<br />everywhere you work
        </h2>
        <p class="mt-4 text-[15px] leading-[1.7] text-gray-500 max-w-lg">
          Every form submission is routed to the tools your team already uses — instantly, reliably, with zero setup.
        </p>
      </div>

      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        <!-- Email -->
        <div class="group relative overflow-hidden rounded-2xl border border-gray-100 bg-white/70 p-5 hover:border-amber-200 hover:bg-amber-50/40 transition-all">
          <div class="flex items-center gap-3 mb-2">
            <svg viewBox="0 0 24 24" fill="none" stroke="#EA4335" stroke-width="1.5" class="h-6 w-6 shrink-0"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0-8.953 5.468a1.5 1.5 0 0 1-1.594 0L2.25 6.75"/></svg>
            <h3 class="text-[15px] font-semibold text-gray-900 group-hover:text-amber-800 transition-colors">Email</h3>
          </div>
          <p class="mt-1 text-[12px] leading-relaxed text-gray-400">Inbox notifications with full submission data</p>
        </div>
        <!-- Slack -->
        <div class="group relative overflow-hidden rounded-2xl border border-gray-100 bg-white/70 p-5 hover:border-amber-200 hover:bg-amber-50/40 transition-all">
          <div class="flex items-center gap-3 mb-2">
            <svg viewBox="0 0 24 24" fill="none" class="h-6 w-6 shrink-0"><path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zm1.271 0a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313z" fill="#E01E5A"/><path d="M8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zm0 1.271a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312z" fill="#36C5F0"/><path d="M18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zm-1.27 0a2.528 2.528 0 0 1-2.522 2.521 2.528 2.528 0 0 1-2.52-2.521V2.522A2.528 2.528 0 0 1 15.165 0a2.528 2.528 0 0 1 2.521 2.522v6.312z" fill="#2EB67D"/><path d="M15.165 18.956a2.528 2.528 0 0 1 2.521 2.522A2.528 2.528 0 0 1 15.165 24a2.527 2.527 0 0 1-2.52-2.522v-2.522h2.52zm0-1.27a2.527 2.527 0 0 1-2.52-2.522 2.527 2.527 0 0 1 2.52-2.52h6.313A2.528 2.528 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.521h-6.313z" fill="#ECB22E"/></svg>
            <h3 class="text-[15px] font-semibold text-gray-900 group-hover:text-amber-800 transition-colors">Slack</h3>
          </div>
          <p class="mt-1 text-[12px] leading-relaxed text-gray-400">Real-time alerts in any channel</p>
        </div>
        <!-- Discord -->
        <div class="group relative overflow-hidden rounded-2xl border border-gray-100 bg-white/70 p-5 hover:border-amber-200 hover:bg-amber-50/40 transition-all">
