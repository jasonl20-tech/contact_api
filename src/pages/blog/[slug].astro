---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getBlogPosts, getBlogPostBySlug } from "../../lib/contentful";
import { renderRichText } from "../../lib/rich-text";

export async function getStaticPaths() {
  let posts: any[] = [];
  try { posts = await getBlogPosts(); } catch { return []; }
  return posts.map((p: any) => ({ params: { slug: p.fields.slug } }));
}

const { slug } = Astro.params;
const post = await getBlogPostBySlug(slug!);
if (!post) return Astro.redirect("/blog");

const f = post.fields as any;
const html = renderRichText(f.body);
---

<BaseLayout title={f.seoTitle || f.title} description={f.seoDescription || f.excerpt}>
  <section class="bg-navy-950 pt-32 pb-16 sm:pt-40 sm:pb-20">
    <div class="mx-auto max-w-3xl px-5 sm:px-8">
      <a href="/blog" class="inline-flex items-center gap-1.5 text-sm font-medium text-amber-400 hover:text-amber-300 transition-colors">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
        Back to Blog
      </a>
      <time class="mt-6 block text-xs font-semibold uppercase tracking-wider text-amber-400">
        {new Date(f.publishedDate).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
      </time>
      <h1 class="mt-3 text-3xl font-extrabold tracking-tight text-white sm:text-4xl lg:text-5xl">
        {f.title}
      </h1>
      {f.author && <p class="mt-4 text-sm text-slate-400">By {f.author}</p>}
    </div>
  </section>

  <article class="bg-white py-12 sm:py-16">
    <div class="mx-auto max-w-3xl px-5 sm:px-8">
      {f.featuredImage && (
        <img
          src={`https:${f.featuredImage.fields.file.url}?w=800`}
          alt={f.featuredImage.fields.title || ""}
          class="-mt-20 mb-10 w-full rounded-2xl shadow-xl"
          loading="lazy"
        />
      )}
      <div class="prose prose-slate prose-lg max-w-none prose-headings:font-extrabold prose-a:text-amber-600 prose-a:no-underline hover:prose-a:underline" set:html={html} />
    </div>
  </article>
</BaseLayout>
