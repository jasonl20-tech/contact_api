---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getBlogPosts, getBlogPostBySlug } from "../../lib/contentful";
import { renderRichText } from "../../lib/rich-text";

export async function getStaticPaths() {
  let posts: any[] = [];
  try { posts = await getBlogPosts(); } catch { return []; }
  return posts.map((p: any) => ({ params: { slug: p.fields.slug } }));
}

const { slug } = Astro.params;
const post = await getBlogPostBySlug(slug!);
if (!post) return Astro.redirect("/blog");

const f = post.fields as any;
const html = renderRichText(f.body);
---

<BaseLayout title={f.seoTitle || f.title} description={f.seoDescription || f.excerpt}>
  <article class="px-5 pt-20 pb-16 sm:pt-28 sm:pb-24">
    <div class="mx-auto max-w-2xl">
      <a href="/blog" class="inline-flex items-center gap-1.5 text-[13px] font-medium text-gray-400 hover:text-gray-900 transition-colors mb-8">
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
        Blog
      </a>

      <time class="text-[11px] font-medium uppercase tracking-widest text-brand-600">
        {new Date(f.publishedDate).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
      </time>
      <h1 class="mt-3 text-2xl sm:text-3xl font-bold tracking-tight text-gray-900">
        {f.title}
      </h1>
      {f.author && <p class="mt-2 text-[13px] text-gray-400">By {f.author}</p>}

      {f.featuredImage && (
        <img
          src={`https:${f.featuredImage.fields.file.url}?w=800`}
          alt={f.featuredImage.fields.title || ""}
          class="mt-8 w-full rounded-2xl"
          loading="lazy"
        />
      )}

      <div class="mt-10 text-[15px] leading-relaxed text-gray-600" set:html={html} />
    </div>
  </article>
</BaseLayout>
