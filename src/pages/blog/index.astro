---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getBlogPosts } from "../../lib/contentful";

let posts: any[] = [];
let error: string | null = null;

try {
  posts = await getBlogPosts();
} catch (e) {
  error = "Blog posts could not be loaded.";
  console.error("Failed to fetch blog posts:", e);
}
---

<BaseLayout title="Blog" description="Guides, updates, and best practices from ContactFormAPI.">
  <section class="bg-navy-950 pt-32 pb-16 sm:pt-40 sm:pb-20">
    <div class="mx-auto max-w-7xl px-5 sm:px-8 text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-amber-400">Blog</p>
      <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
        Guides & Updates
      </h1>
      <p class="mx-auto mt-4 max-w-lg text-lg text-slate-400">
        Tips, tutorials, and news about form handling.
      </p>
    </div>
  </section>

  <section class="bg-white py-16 sm:py-24">
    <div class="mx-auto max-w-5xl px-5 sm:px-8">
      {error && (
        <div class="mx-auto mb-8 max-w-md rounded-xl border border-amber-200 bg-amber-50 p-4 text-center text-sm text-amber-800">
          {error}
        </div>
      )}

      {posts.length > 0 ? (
        <div class="grid gap-8 md:grid-cols-2">
          {posts.map((post: any) => {
            const f = post.fields as any;
            return (
              <a
                href={`/blog/${f.slug}`}
                class="group overflow-hidden rounded-2xl border border-slate-100 bg-white transition-all duration-300 hover:border-amber-200 hover:shadow-xl hover:shadow-amber-100/30"
              >
                {f.featuredImage && (
                  <div class="aspect-video overflow-hidden bg-slate-50">
                    <img
                      src={`https:${f.featuredImage.fields.file.url}?w=600&h=340&fit=fill`}
                      alt={f.featuredImage.fields.title || ""}
                      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="p-6">
                  <time class="text-xs font-semibold uppercase tracking-wider text-amber-600">
                    {new Date(f.publishedDate).toLocaleDateString("en-US", {
                      year: "numeric", month: "long", day: "numeric",
                    })}
                  </time>
                  <h2 class="mt-2 text-lg font-bold text-slate-900 group-hover:text-amber-600 transition-colors">
                    {f.title}
                  </h2>
                  <p class="mt-2 text-sm leading-relaxed text-slate-500 line-clamp-3">
                    {f.excerpt}
                  </p>
                </div>
              </a>
            );
          })}
        </div>
      ) : !error && (
        <div class="text-center py-12">
          <p class="text-slate-400 text-lg">No blog posts yet. Check back soon!</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
